<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/disk_icon_desc"
                android:src="@drawable/ic_nav_disk" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_path"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/row_extra_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_resize"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="@string/disk_resize"
            app:icon="@drawable/ic_resize"
            tools:ignore="VisualLintButtonSize" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_convert"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="@string/disk_set_format"
            app:icon="@drawable/ic_disk_format"
            tools:ignore="VisualLintButtonSize" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_extra_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_optimize"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="@string/disk_optimize"
            app:icon="@drawable/ic_speedometer"
            tools:ignore="VisualLintButtonSize" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_create_increment"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="@string/disk_create_increment"
            app:icon="@drawable/ic_file_multiple"
            tools:ignore="VisualLintButtonSize" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clone"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="@string/disk_clone"
            app:icon="@drawable/ic_card_multiple"
            tools:ignore="VisualLintButtonSize" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="@string/disk_delete"
            android:textColor="?attr/colorError"
            app:icon="@drawable/ic_delete"
            app:iconTint="?attr/colorError"
            app:strokeColor="?attr/colorError"
            tools:ignore="VisualLintButtonSize" />

    </LinearLayout>

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

    <cn.classfun.droidvm.ui.widgets.container.CollapsibleContainer
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:title="@string/disk_info_section_basic"
        app:cc_collapsible="false">

        <cn.classfun.droidvm.ui.widgets.row.TextRowWidget
            android:id="@+id/row_filename"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:icon="@drawable/ic_file"
            android:text="@string/disk_info_filename" />

        <cn.classfun.droidvm.ui.widgets.row.TextRowWidget
            android:id="@+id/row_folder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:icon="@drawable/ic_folder"
            android:text="@string/disk_info_folder" />

        <cn.classfun.droidvm.ui.widgets.row.TextRowWidget
            android:id="@+id/row_format"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:icon="@drawable/ic_disk_format"
            android:text="@string/disk_info_format" />

        <cn.classfun.droidvm.ui.widgets.row.TextRowWidget
            android:id="@+id/row_virtual_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:icon="@drawable/ic_resize"
            android:text="@string/disk_info_virtual_size" />

        <cn.classfun.droidvm.ui.widgets.row.TextRowWidget
            android:id="@+id/row_actual_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:icon="@drawable/ic_nav_disk"
            android:text="@string/disk_info_actual_size" />

    </cn.classfun.droidvm.ui.widgets.container.CollapsibleContainer>

    <cn.classfun.droidvm.ui.widgets.container.CollapsibleContainer
        android:id="@+id/section_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:title="@string/disk_info_section_details"
        android:visibility="gone">

        <cn.classfun.droidvm.ui.widgets.row.TextRowWidget
            android:id="@+id/row_cluster_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:icon="@drawable/ic_card_multiple"
            android:text="@string/disk_info_cluster_size" />

        <cn.classfun.droidvm.ui.widgets.row.TextRowWidget
            android:id="@+id/row_backing_file"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:icon="@drawable/ic_source_branch"
            android:text="@string/disk_info_backing_file" />

        <cn.classfun.droidvm.ui.widgets.row.TextRowWidget
            android:id="@+id/row_encryption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:icon="@drawable/ic_lock"
            android:text="@string/disk_info_encryption" />

        <cn.classfun.droidvm.ui.widgets.row.TextRowWidget
            android:id="@+id/row_compression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:icon="@drawable/ic_compress"
            android:text="@string/disk_info_compression" />

        <cn.classfun.droidvm.ui.widgets.row.TextRowWidget
            android:id="@+id/row_dirty_flag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:icon="@drawable/ic_info"
            android:text="@string/disk_info_dirty_flag" />

    </cn.classfun.droidvm.ui.widgets.container.CollapsibleContainer>

    <cn.classfun.droidvm.ui.widgets.container.CollapsibleContainer
        android:id="@+id/section_raw"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:title="@string/disk_info_section_raw"
        app:cc_collapsible="true">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <TextView
                android:id="@+id/tv_raw_output"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:padding="12dp"
                android:text="@string/disk_info_loading"
                android:textSize="12sp" />

        </com.google.android.material.card.MaterialCardView>

    </cn.classfun.droidvm.ui.widgets.container.CollapsibleContainer>

    <Space
        android:layout_width="match_parent"
        android:layout_height="128dp"
        tools:ignore="VisualLintBounds" />

</LinearLayout>

