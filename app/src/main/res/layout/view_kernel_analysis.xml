<?xml version="1.0" encoding="utf-8"?>
<!-- Reusable "kernel analysis" card: an Analyze button that runs one cloud
     analysis (lbx entries <url>) and shows, per boot entry, the kernel /
     initrd / cmdline plus the protected-VM DMA warning - mirroring the VM
     edit screen's boot-detection card. Driven by KernelAnalysisWidget. -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/kernel_analysis_title"
                android:textColor="@color/kernel_analysis_title"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progress_analysis"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorSize="20dp"
                app:trackThickness="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_analyze"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="@string/kernel_analysis_analyze"
                app:icon="@drawable/ic_linux"
                app:iconSize="18dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_analysis_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="6dp"
            android:text="@string/kernel_analysis_hint"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/group_analysis_results"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <cn.classfun.droidvm.ui.widgets.row.DropdownRowWidget
                android:id="@+id/dd_analysis_entry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/edit_vm_boot_entry"
                android:icon="@drawable/ic_linux" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:hint="@string/edit_vm_boot_detect_kernel">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_analysis_kernel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textSize="14sp"
                    tools:ignore="TextContrastCheck,VisualLintTextFieldSize" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tv_analysis_dma_warn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp"
                android:textColor="?attr/colorError"
                android:textSize="12sp"
                android:visibility="gone" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/edit_vm_boot_detect_initrd">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_analysis_initrd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textSize="14sp"
                    tools:ignore="TextContrastCheck,VisualLintTextFieldSize" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/edit_vm_boot_detect_cmdline">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_analysis_cmdline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:textSize="14sp"
                    tools:ignore="TextContrastCheck,VisualLintTextFieldSize" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
