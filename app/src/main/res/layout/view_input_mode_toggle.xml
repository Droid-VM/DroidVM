<?xml version="1.0" encoding="utf-8"?>
<!-- Segmented input-mode selector shown as the display fab-menu header: one row of three
     icon buttons (touch / tablet / mouse), single-selection, the active mode checked. -->
<com.google.android.material.button.MaterialButtonToggleGroup
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/input_mode_group"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="2dp"
    app:singleSelection="true"
    app:selectionRequired="true">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/mode_touch"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="60dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:contentDescription="@string/vnc_menu_input_mode_touch"
        app:icon="@drawable/ic_touchpad"
        app:iconGravity="textStart"
        app:iconPadding="0dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/mode_tablet"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="60dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:contentDescription="@string/vnc_menu_input_mode_tablet"
        app:icon="@drawable/ic_stylus"
        app:iconGravity="textStart"
        app:iconPadding="0dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/mode_mouse"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="60dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:contentDescription="@string/vnc_menu_input_mode_mouse"
        app:icon="@drawable/ic_mouse"
        app:iconGravity="textStart"
        app:iconPadding="0dp" />

</com.google.android.material.button.MaterialButtonToggleGroup>
